# syntax=docker/dockerfile:1.7
# Web container: build the SPA with Vite, serve static assets with nginx.

FROM node:20-slim AS builder
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@latest --activate

COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

COPY . .
# Prisma generate is needed because client/trpc.ts imports `type AppRouter`,
# which transitively type-checks server/db.ts -> generated/prisma. Vite's tsc
# resolution requires the generated client to exist on disk.
RUN pnpm exec prisma generate
RUN pnpm run build

FROM nginx:1.27-alpine AS app
COPY --from=builder /app/dist/client /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
